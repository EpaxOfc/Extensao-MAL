{
  "manifest_version": 3,
  "name": "MAL Notas Extras",
  "version": "7.0",
  "key": "",
  "description": "Review automático com integração MAL.",
  "permissions": ["storage", "activeTab", "scripting", "identity"],
  "host_permissions": ["https://api.jikan.moe/*", "https://myanimelist.net/*", "https://api.myanimelist.net/*"],
  "content_scripts": [
    {
      "matches": ["*://drive.google.com/*", "*://www.crunchyroll.com/*", "*://www.netflix.com/*"],
      "js": ["content.js"],
      "css": ["overlay.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["lista.html", "lista.js", "lista.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": { "16": "icon.png", "48": "icon.png", "128": "icon.png" }
}
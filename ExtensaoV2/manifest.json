{
  "manifest_version": 3,
  "name": "MAL Notas Extras",
  "version": "7.0",
  "key": "",
  "description": "Review automático com integração MAL.",
  "permissions": ["storage", "activeTab", "scripting", "identity", "sidePanel", "tabs"],
  "side_panel": {
    "default_path": "popup.html"
  },
  "sidebar_action": {
    "default_icon": "icon.png",
    "default_title": "MAL Notas Extras",
    "default_panel": "popup.html"
  },
  "host_permissions": [
    "https://api.jikan.moe/*", 
    "https://myanimelist.net/*", 
    "https://api.myanimelist.net/*",
    "https://graphql.anilist.co/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["lista.html", "lista.js", "lista.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": { "16": "icon.png", "48": "icon.png", "128": "icon.png" }
}